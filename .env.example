# Linkon environment template
# Copy to .env.local and fill with fresh Supabase/Vercel values.
# Keep service-role keys and webhook secrets server-side only.

# Linkon canonical Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Linkon deployment and first super admin
NEXT_PUBLIC_APP_URL=
LINKON_SUPER_ADMIN_EMAIL=
LINKON_WEBHOOK_SECRET=

# Downstream service projects.
# Leave a service blank until it is ready to receive Linkon users.
VION_SUPABASE_URL=
VION_SERVICE_ROLE_KEY=
NEXT_PUBLIC_VION_URL=

RION_SUPABASE_URL=
RION_SERVICE_ROLE_KEY=
NEXT_PUBLIC_RION_URL=

TAXON_SUPABASE_URL=
TAXON_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TAXON_URL=
